generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PerfilAcesso {
  ADMIN
  USUARIO
}

enum StatusProcesso {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model Usuario {
  id           String       @id @default(cuid())
  nome         String
  email        String       @unique
  senha        String
  perfilAcesso PerfilAcesso @default(USUARIO)
  ativo        Boolean      @default(true)
  permissoes   Json         @default("{}")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  logs LogAuditoria[]

  @@map("usuarios")
}

model LogAuditoria {
  id         String   @id @default(cuid())
  usuarioId  String?
  acao       String
  entidade   String
  entidadeId String?
  descricao  String?
  createdAt  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("logs_auditoria")
}

model Cliente {
  id          String  @id @default(cuid())
  nome        String
  cpfCnpj     String  @unique
  telefone    String?
  email       String?
  cidade      String?
  endereco    String?
  observacoes String?
  ativo       Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propriedades Propriedade[]
  processos    Processo[]
  documentos   Documento[]

  @@map("clientes")
}

model Propriedade {
  id          String   @id @default(cuid())
  clienteId   String
  nome        String
  cep         String?
  municipio   String
  uf          String?
  area        Float?
  matricula   String?
  car         String?
  ccir        String?
  coordenadas String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente    Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  processos  Processo[]
  documentos Documento[]

  @@map("propriedades")
}

model Colaborador {
  id        String   @id @default(cuid())
  nome      String
  cpf       String?  @unique
  email     String?
  cargo     String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipesComoMembro     EquipeColaborador[]
  equipesComoResponsavel Equipe[]            @relation("EquipeResponsavel")

  @@map("colaboradores")
}

model Equipe {
  id              String   @id @default(cuid())
  nome            String
  telefone        String?
  responsavelId   String?
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  responsavel  Colaborador?        @relation("EquipeResponsavel", fields: [responsavelId], references: [id])
  membros      EquipeColaborador[]
  processos    Processo[]

  @@map("equipes")
}

model EquipeColaborador {
  equipeId      String
  colaboradorId String

  equipe      Equipe      @relation(fields: [equipeId], references: [id], onDelete: Cascade)
  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@id([equipeId, colaboradorId])
  @@map("equipe_colaboradores")
}

model Processo {
  id            String         @id @default(cuid())
  protocolo     String         @unique
  clienteId     String
  propriedadeId String?
  equipeId      String?
  tipoServico   String
  status        StatusProcesso @default(PENDENTE)
  valor         Float?
  dataInicio    DateTime       @default(now())
  dataFim       DateTime?
  observacoes   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  cliente     Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propriedade Propriedade? @relation(fields: [propriedadeId], references: [id])
  equipe      Equipe?      @relation(fields: [equipeId], references: [id])
  historico   HistoricoProcesso[]
  documentos  Documento[]

  @@map("processos")
}

model HistoricoProcesso {
  id         String         @id @default(cuid())
  processoId String
  descricao  String
  status     StatusProcesso
  createdAt  DateTime       @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@map("historico_processos")
}

model MensagemDoDia {
  id         String   @id @default(cuid())
  conteudo   String
  ativa      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("mensagens_do_dia")
}

model Documento {
  id            String   @id @default(cuid())
  clienteId     String?
  propriedadeId String?
  processoId    String?
  nomeArquivo   String
  nomeOriginal  String
  tipo          String
  tamanho       Int
  caminho       String
  createdAt     DateTime @default(now())

  cliente     Cliente?     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propriedade Propriedade? @relation(fields: [propriedadeId], references: [id])
  processo    Processo?    @relation(fields: [processoId], references: [id])

  @@map("documentos")
}
