generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PerfilAcesso {
  ADMIN
  USUARIO
}

enum Setor {
  GEO
  AMBIENTAL
  IMOVEIS
}

enum StatusProcesso {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum StatusOrcamento {
  PENDENTE
  APROVADO
  REJEITADO
}

enum CategoriaImovel {
  URBANO
  RURAL
}

enum StatusImovel {
  DISPONIVEL
  VENDIDO
}

model Usuario {
  id           String       @id @default(cuid())
  nome         String
  email        String       @unique
  senha        String
  perfilAcesso PerfilAcesso @default(USUARIO)
  ativo        Boolean      @default(true)
  permissoes   Json         @default("{}")
  setores      Setor[]      @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  logs              LogAuditoria[]
  orcamentosCriados Orcamento[]
  imoveisResponsavel Imovel[]

  @@map("usuarios")
}

model LogAuditoria {
  id         String   @id @default(cuid())
  usuarioId  String?
  acao       String
  entidade   String
  entidadeId String?
  descricao  String?
  createdAt  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("logs_auditoria")
}

model Cliente {
  id          String  @id @default(cuid())
  nome        String
  cpfCnpj     String  @unique
  telefone    String?
  email       String?
  cidade      String?
  endereco    String?
  observacoes String?
  setores     Setor[]  @default([])
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propriedades  Propriedade[]
  processos     Processo[]
  orcamentos    Orcamento[]
  documentos    Documento[]
  imoveis       Imovel[]
  imoveisInteresse ImovelInteressado[]
  visitasImovel VisitaImovel[]

  @@map("clientes")
}

model Propriedade {
  id          String   @id @default(cuid())
  clienteId   String
  nome        String
  cep         String?
  municipio   String
  uf          String?
  area        Float?
  matricula   String?
  car         String?
  ccir        String?
  coordenadas String?
  setores     Setor[]  @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente    Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  processos  Processo[]
  orcamentos Orcamento[]
  documentos Documento[]

  @@map("propriedades")
}

model Colaborador {
  id        String   @id @default(cuid())
  nome      String
  cpf       String?  @unique
  email     String?
  cargo     String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipesComoMembro     EquipeColaborador[]
  equipesComoResponsavel Equipe[]            @relation("EquipeResponsavel")

  @@map("colaboradores")
}

model Equipe {
  id              String   @id @default(cuid())
  nome            String
  telefone        String?
  responsavelId   String?
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  responsavel  Colaborador?        @relation("EquipeResponsavel", fields: [responsavelId], references: [id])
  membros      EquipeColaborador[]
  processos    Processo[]

  @@map("equipes")
}

model EquipeColaborador {
  equipeId      String
  colaboradorId String

  equipe      Equipe      @relation(fields: [equipeId], references: [id], onDelete: Cascade)
  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@id([equipeId, colaboradorId])
  @@map("equipe_colaboradores")
}

model Processo {
  id            String         @id @default(cuid())
  protocolo     String         @unique
  clienteId     String
  propriedadeId String?
  equipeId      String?
  tipoServico   String
  status        StatusProcesso @default(PENDENTE)
  valor         Float?
  dataInicio    DateTime       @default(now())
  dataFim       DateTime?
  observacoes   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  cliente     Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propriedade Propriedade? @relation(fields: [propriedadeId], references: [id])
  equipe      Equipe?      @relation(fields: [equipeId], references: [id])
  historico   HistoricoProcesso[]
  documentos  Documento[]
  orcamento   Orcamento?

  @@map("processos")
}

model Orcamento {
  id                 String          @id @default(cuid())
  protocolo          String          @unique
  clienteId          String
  propriedadeId      String?
  tipoServico        String
  descricao          String?
  valor              Float?
  condicoesPagamento String?
  prazoExecucaoDias  Int?
  validadeAte        DateTime?
  observacoes        String?
  status             StatusOrcamento @default(PENDENTE)
  motivoRejeicao     String?
  atividades         Json?
  processoId         String?         @unique
  usuarioId          String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  cliente     Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propriedade Propriedade? @relation(fields: [propriedadeId], references: [id])
  processo    Processo?    @relation(fields: [processoId], references: [id])
  criadoPor   Usuario?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("orcamentos")
}

model SequenciaProtocolo {
  ano           Int @id
  ultimoNumero  Int @default(0)

  @@map("sequencia_protocolo")
}

model HistoricoProcesso {
  id         String         @id @default(cuid())
  processoId String
  descricao  String
  status     StatusProcesso
  createdAt  DateTime       @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@map("historico_processos")
}

model MensagemDoDia {
  id         String   @id @default(cuid())
  conteudo   String
  ativa      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("mensagens_do_dia")
}

model Documento {
  id            String   @id @default(cuid())
  clienteId     String?
  propriedadeId String?
  processoId    String?
  imovelId      String?
  nomeArquivo   String
  nomeOriginal  String
  tipo          String
  tamanho       Int
  caminho       String
  createdAt     DateTime @default(now())

  cliente     Cliente?     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propriedade Propriedade? @relation(fields: [propriedadeId], references: [id])
  processo    Processo?    @relation(fields: [processoId], references: [id])
  imovel      Imovel?      @relation(fields: [imovelId], references: [id], onDelete: Cascade)

  @@map("documentos")
}

model Imovel {
  id              String          @id @default(cuid())
  clienteId       String
  corretorId      String?
  categoria       CategoriaImovel
  tipo            String
  status          StatusImovel    @default(DISPONIVEL)
  valor           Float?
  exclusividade   Boolean         @default(false)
  dataCaptacao    DateTime?
  localizacao     String?
  cep             String?
  rua             String?
  numero          String?
  bairro          String?
  cidade          String?
  estado          String?
  areaM2          Float?
  areaTotal       Float?
  areaUtil        Float?
  areaReservaLegal Float?
  areaApp         Float?
  areaAberta      Float?
  areaMata        Float?
  observacoes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  cliente      Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  corretor     Usuario?           @relation(fields: [corretorId], references: [id], onDelete: SetNull)
  interessados ImovelInteressado[]
  visitas      VisitaImovel[]
  documentos   Documento[]

  @@map("imoveis")
}

model ImovelInteressado {
  imovelId  String
  clienteId String

  imovel  Imovel  @relation(fields: [imovelId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@id([imovelId, clienteId])
  @@map("imovel_interessados")
}

model VisitaImovel {
  id          String   @id @default(cuid())
  imovelId    String
  clienteId   String?
  data        DateTime
  observacoes String?
  createdAt   DateTime @default(now())

  imovel  Imovel   @relation(fields: [imovelId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@map("visitas_imovel")
}
